# ==============================================================================
# REFERENCE FILE — do not put real secrets here.
# Sensitive variables (passwords, API keys, passphrase) must be passed via
# TF_VAR_* environment variables from your secrets manager.
# See docs/05-security-and-secrets.md for the full procedure.
# ==============================================================================

####################################
# State  (SECRET — do NOT set here)
####################################

# tofu_state_passphrase  → export TF_VAR_tofu_state_passphrase="..."

####################################
# OVH credentials  (SECRET — do NOT set here, except the endpoint)
####################################

ovh_endpoint = "ovh-eu"
# ovh_application_key     → export TF_VAR_ovh_application_key="..."
# ovh_application_secret  → export TF_VAR_ovh_application_secret="..."
# ovh_consumer_key        → export TF_VAR_ovh_consumer_key="..."

####################################
# Common
####################################

compute_region      = "GRA11"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# IP (or CIDR) allowed to reach the OPNsense WebGUI (8443) and SSH (22).
# Prefer a single fixed IP; a broad range such as /24 is overly permissive.
admin_client_ip = "203.0.113.42"

# OPNsense accounts  (SECRET — do NOT set here)
# admin_password  → export TF_VAR_admin_password="..."
# ha_password     → export TF_VAR_ha_password="..."

####################################
# Hub addressing
####################################

hub_flavor            = "b3-16"
hub_net_wan_vlan_id   = 100
hub_private_wan_cidr  = "10.1.0.0/24"
hub_net_lan_vlan_id   = 200
hub_private_lan_cidr  = "192.168.10.0/24"
hub_net_hasync_vlan_id = 199
hub_private_hasync_cidr = "10.0.254.0/30"
