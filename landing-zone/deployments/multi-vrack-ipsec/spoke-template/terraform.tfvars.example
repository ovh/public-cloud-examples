########################################################################################
# REFERENCE FILE — do not put real secrets here.
# Sensitive variables (passwords, API keys, PSK, passphrase) must be passed via
# TF_VAR_* environment variables from your secrets manager.
# See docs/05-security-and-secrets.md for the full procedure.
########################################################################################

########################################################################################
# Spoke Day-2 template - example values
########################################################################################

# OVH API credentials
ovh_endpoint           = "ovh-eu"
ovh_application_key    = "xxxx"
ovh_application_secret = "xxxx"
ovh_consumer_key       = "xxxx"

# OpenStack region
compute_region = "GRA11"

# Admin access (same secret as hub Day-1)
admin_client_ip = "203.0.113.10/24"
admin_password  = "CHANGE_ME"
ha_password     = "CHANGE_ME"

# Hub references (from deployments/landing-zone outputs)
hub_floating_ip      = "141.94.10.231"
hub_wan_carp_ip      = "10.1.0.99"
hub_private_wan_cidr = "10.1.0.0/24"
hub_api_key          = "xxxx" # tofu output hub_api_key
hub_api_secret       = "xxxx" # tofu output -raw hub_api_secret

# Spoke naming
spoke_project_description = "spoke-prod"
spoke_vrack_name          = "spoke-prod-vrack"
spoke_vrack_description   = "Spoke prod vRack"

# Spoke sizing
spoke_flavor = "b3-8"

# Spoke networks (must be unique per spoke)
spoke_net_wan_vlan_id    = 410
spoke_net_lan_vlan_id    = 411
spoke_net_hasync_vlan_id = 412

spoke_private_wan_cidr    = "10.4.0.0/24"
spoke_private_lan_cidr    = "192.168.40.0/24"
spoke_private_hasync_cidr = "10.0.252.0/30"

# IPsec parameters (must be unique per spoke)
ipsec_reqid       = 100
vti_link_cidr      = "169.254.0.8/30"
ipsec_pre_shared_key = "CHANGE_ME"

# Optional SSH key to inject into OPNsense
# ssh_public_key_path = "~/.ssh/id_rsa.pub"

