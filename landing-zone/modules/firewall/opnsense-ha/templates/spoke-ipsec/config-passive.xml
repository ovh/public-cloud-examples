<?xml version="1.0"?>
<opnsense>
  <sysctl>
    <item>
      <descr>Enable unicast CARP</descr>
      <tunable>net.inet.carp.allow_unicast</tunable>
      <value>1</value>
    </item>
    <item>
      <descr>Allow CARP preemption</descr>
      <tunable>net.inet.carp.preempt</tunable>
      <value>1</value>
    </item>
    <item>
      <descr>IPsec multithread crypto</descr>
      <tunable>net.inet.ipsec.async_crypto</tunable>
      <value>1</value>
    </item>
    <item>
      <descr>Max socket buffer size</descr>
      <tunable>kern.ipc.maxsockbuf</tunable>
      <value>16777216</value>
    </item>
    <item>
      <descr>TCP send buffer max</descr>
      <tunable>net.inet.tcp.sendbuf_max</tunable>
      <value>16777216</value>
    </item>
    <item>
      <descr>TCP receive buffer max</descr>
      <tunable>net.inet.tcp.recvbuf_max</tunable>
      <value>16777216</value>
    </item>
    <item>
      <descr>Fast IP forwarding</descr>
      <tunable>net.inet.ip.fastforwarding</tunable>
      <value>1</value>
    </item>
    <item>
      <descr>Deferred netisr dispatch for multi-core</descr>
      <tunable>net.isr.dispatch</tunable>
      <value>deferred</value>
    </item>
    <item>
      <descr>Interface queue length</descr>
      <tunable>net.link.ifqmaxlen</tunable>
      <value>2048</value>
    </item>
    <item>
      <descr>IP input queue length</descr>
      <tunable>net.inet.ip.intr_queue_maxlen</tunable>
      <value>4096</value>
    </item>
  </sysctl>
  <system>
    <hostname>${HOSTNAME}</hostname>
    <domain>ovh.internal</domain>
    <dnsserver>213.186.33.99</dnsserver>
    <user>
      <uid>0</uid>
      <name>root</name>
      <password>${bcrypt(ADMIN_PASSWORD)}</password>
      <priv>page-all</priv>
    </user>
    <user>
      <uid>2000</uid>
      <name>admin</name>
      <password>${bcrypt(ADMIN_PASSWORD)}</password>
      <authorizedkeys>${base64encode(ADMIN_SSH_KEY)}</authorizedkeys>
      <shell>/bin/sh</shell>
      <priv>page-all</priv>
      <priv>user-ssh</priv>
      <groupname>wheel</groupname>
      <groupname>admins</groupname>
    </user>
    <user>
      <uid>2001</uid>
      <name>haadmin</name>
      <password>${bcrypt(HA_PASSWORD)}</password>
      <priv>page-all</priv>
      <groupname>admins</groupname>
    </user>
    <group>
      <name>admins</name>
      <priv>page-all</priv>
      <member>2000</member>
    </group>
    <group>
      <name>wheel</name>
      <member>2000</member>
    </group>
    <ssh>
      <enabled>enabled</enabled>
      <group>admins</group>
      <permitrootlogin>1</permitrootlogin>
      <passwordauth>0</passwordauth>
      <pubkeyacceptedalgorithms>ssh-ed25519,rsa-sha2-512,rsa-sha2-256,+ssh-rsa</pubkeyacceptedalgorithms>
    </ssh>
    <webgui>
      <protocol>https</protocol>
      <port>8443</port>
      <nohttpreferercheck>1</nohttpreferercheck>
    </webgui>
  </system>
  <interfaces>
    <wan>
      <if>vtnet0</if>
      <enable>1</enable>
      <ipaddr>${WAN_PORT_IP}</ipaddr>
      <subnet>${WAN_PORT_NETMASK}</subnet>
      <descr>WAN</descr>
      <blockpriv>0</blockpriv>
      <blockbogons>0</blockbogons>
    </wan>
    <lan>
      <if>vtnet1</if>
      <enable>1</enable>
      <ipaddr>${LAN_PORT_IP}</ipaddr>
      <subnet>${LAN_PORT_NETMASK}</subnet>
      <descr>LAN</descr>
      <blockpriv>0</blockpriv>
      <blockbogons>0</blockbogons>
    </lan>
    <hasync>
      <if>vtnet2</if>
      <enable>1</enable>
      <ipaddr>${HASYNC_PORT_IP}</ipaddr>
      <subnet>${HASYNC_PORT_NETMASK}</subnet>
      <descr>HASYNC</descr>
      <blockpriv>0</blockpriv>
      <blockbogons>0</blockbogons>
    </hasync>
  </interfaces>
  <gateways>
    <gateway_item>
      <interface>wan</interface>
      <gateway>${WAN_GATEWAY_IP}</gateway>
      <name>WANGW</name>
      <priority>255</priority>
      <weight>1</weight>
      <ipprotocol>inet</ipprotocol>
      <defaultgw>1</defaultgw>
    </gateway_item>
  </gateways>
  <virtualip>
    <vip>
      <mode>carp</mode>
      <interface>wan</interface>
      <vhid>11</vhid>
      <advbase>1</advbase>
      <advskew>100</advskew>
      <password>${HA_PASSWORD}</password>
      <subnet>${WAN_CARP_IP}</subnet>
      <subnet_bits>${WAN_PORT_NETMASK}</subnet_bits>
      <peer>${PEER_WAN_IP}</peer>
      <descr>WAN CARP VIP</descr>
      <type>single</type>
      <uniqid>wan-carp-vip</uniqid>
    </vip>
    <vip>
      <mode>carp</mode>
      <interface>lan</interface>
      <vhid>13</vhid>
      <advbase>1</advbase>
      <advskew>100</advskew>
      <password>${HA_PASSWORD}</password>
      <subnet>${LAN_CARP_IP}</subnet>
      <subnet_bits>${LAN_PORT_NETMASK}</subnet_bits>
      <peer>${PEER_LAN_IP}</peer>
      <descr>LAN CARP VIP</descr>
      <type>single</type>
      <uniqid>lan-carp-vip</uniqid>
    </vip>
  </virtualip>
  <pfsync>
    <enabled>1</enabled>
    <pfsyncinterface>vtnet2</pfsyncinterface>
    <pfsyncpeerip>${PEER_HA_IP}</pfsyncpeerip>
  </pfsync>
  <filter>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <direction>in</direction>
      <protocol>tcp</protocol>
      <source>
        <address>${ADMIN_CLIENT_IP}</address>
      </source>
      <destination>
        <any/>
        <port>8443</port>
      </destination>
      <descr>Allow WebGUI access from Admin IP</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <direction>in</direction>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <any/>
        <port>22</port>
      </destination>
      <descr>Allow SSH on WAN</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <direction>in</direction>
      <protocol>tcp</protocol>
      <source>
        <address>${ADMIN_CLIENT_IP}</address>
      </source>
      <destination>
        <any/>
        <port>8443</port>
      </destination>
      <descr>Allow WebGUI access from Admin IP</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <direction>in</direction>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <any/>
        <port>22</port>
      </destination>
      <descr>Allow SSH on LAN</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>hasync</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>pfsync</protocol>
      <source>
        <network>hasync</network>
      </source>
      <destination>
        <network>hasync</network>
      </destination>
      <descr>Allow pfsync on HASYNC</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>hasync</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source>
        <network>hasync</network>
      </source>
      <destination>
        <network>hasync</network>
        <port>8443</port>
      </destination>
      <descr>Allow xmlrpc on HASYNC</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>carp</protocol>
      <source>
        <network>wan</network>
      </source>
      <destination>
        <network>wan</network>
      </destination>
      <descr>Allow unicast CARP on WAN</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>carp</protocol>
      <source>
        <address>lan</address>
      </source>
      <destination>
        <address>lan</address>
      </destination>
      <descr>Allow unicast CARP on LAN</descr>
    </rule>
  </filter>
  <OPNsense>
    <Syslog>
      <general>
        <enabled>1</enabled>
        <loglocal>1</loglocal>
        <maxpreserve>31</maxpreserve>
      </general>
    </Syslog>
  </OPNsense>
</opnsense>
