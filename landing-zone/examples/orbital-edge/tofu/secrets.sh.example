#!/usr/bin/env bash
# secrets.sh.example — OrbitalEdge secrets management template
#
# Usage:
#   cp secrets.sh.example secrets.sh
#   vim secrets.sh          # fill in the values
#   source secrets.sh       # export into the current shell
#   tofu apply              # TF_VAR_* values are picked up by OpenTofu automatically
#
# This file MUST NEVER be committed. It is in .gitignore.
# In CI/CD, inject these variables from your vault or the platform's native secrets.

# ─── State encryption ────────────────────────────────────────────────────────
export TF_VAR_tofu_state_passphrase=""

# ─── OVHcloud API credentials ────────────────────────────────────────────────
# Create the tokens in the OVHcloud Manager: https://www.ovh.com/auth/api/createToken
export TF_VAR_ovh_application_key=""
export TF_VAR_ovh_application_secret=""
export TF_VAR_ovh_consumer_key=""

# ─── OPNsense — Hub only (Day-1) ─────────────────────────────────────────────
export TF_VAR_admin_password=""   # OPNsense admin account password
export TF_VAR_ha_password=""      # CARP / xmlrpc HA password

# ─── OPNsense API — Spokes only (Day-2) ──────────────────────────────────────
# Retrieve these values after tofu apply in hub/:
#   tofu -chdir=hub output -raw hub_api_key
#   tofu -chdir=hub output -raw hub_api_secret
export TF_VAR_hub_api_key=""
export TF_VAR_hub_api_secret=""
