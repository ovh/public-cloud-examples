# examples/orbital-edge/tofu/spoke-constellation-prod/terraform.tfvars.example
# Configuration only. Secrets go through TF_VAR_* — see secrets.sh.example.

ovh_endpoint   = "ovh-eu"
compute_region = "EU-WEST-PAR"
spoke_name     = "constellation-prod"

# Hub references — fill in from the hub outputs (tofu -chdir=../hub output …)
hub_vrack_service_name = "REPLACE_ME"
hub_floating_ip        = "REPLACE_ME"
hub_lan_carp_ip        = "192.168.10.99"

hub_lan_vlan_id   = 200
hub_lan_cidr      = "192.168.10.0/24"

# Distinct from constellation-dev (.10)
transit_router_ip = "192.168.10.20"

# constellation-prod spoke LAN networks
networks = {
  "kube" = {
    vlan_id = 400
    cidr    = "10.40.0.0/24"
  }
}

iam_ci_service_account_login = "REPLACE_ME"
