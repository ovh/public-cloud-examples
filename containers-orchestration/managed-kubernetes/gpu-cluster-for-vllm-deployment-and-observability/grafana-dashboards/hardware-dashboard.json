{
    "dashboard": {
      "title": "Hardware Metrics - GPU Nodes",
      "uid": "hardware-metrics",
      "tags": ["hardware", "gpu", "cpu", "memory"],
      "timezone": "browser",
      "refresh": "30s",
      "time": {
        "from": "now-1h",
        "to": "now"
      },
      "panels": [
        {
          "id": 1,
          "title": "GPU Utilization (per node)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "DCGM_FI_DEV_GPU_UTIL{namespace='gpu-operator'}",
              "legendFormat": "{{kubernetes_node}} - GPU {{gpu}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 20,
                "showPoints": "never"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "blue"
                  },
                  {
                    "value": 50,
                    "color": "green"
                  },
                  {
                    "value": 80,
                    "color": "yellow"
                  },
                  {
                    "value": 95,
                    "color": "red"
                  }
                ]
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 2,
          "title": "GPU Memory Usage (GB)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 0
          },
          "targets": [
            {
              "expr": "DCGM_FI_DEV_FB_USED{namespace='gpu-operator'} / 1024",
              "legendFormat": "{{kubernetes_node}} - Used",
              "refId": "A"
            },
            {
              "expr": "DCGM_FI_DEV_FB_FREE{namespace='gpu-operator'} / 1024",
              "legendFormat": "{{kubernetes_node}} - Free",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "decgbytes",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 10
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*Free.*"
                },
                "properties": [
                  {
                    "id": "custom.fillOpacity",
                    "value": 0
                  }
                ]
              }
            ]
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 3,
          "title": "GPU Temperature",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 8
          },
          "targets": [
            {
              "expr": "DCGM_FI_DEV_GPU_TEMP{namespace='gpu-operator'}",
              "legendFormat": "{{kubernetes_node}} - GPU {{gpu}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "celsius",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 10
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "green"
                  },
                  {
                    "value": 70,
                    "color": "yellow"
                  },
                  {
                    "value": 85,
                    "color": "red"
                  }
                ]
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 4,
          "title": "GPU Power Usage (Watts)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 8
          },
          "targets": [
            {
              "expr": "DCGM_FI_DEV_POWER_USAGE{namespace='gpu-operator'}",
              "legendFormat": "{{kubernetes_node}} - GPU {{gpu}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "watt",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 5,
          "title": "CPU Usage (per node)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 16
          },
          "targets": [
            {
              "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 15
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 6,
          "title": "Memory Usage (per node)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 16
          },
          "targets": [
            {
              "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 15
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "green"
                  },
                  {
                    "value": 70,
                    "color": "yellow"
                  },
                  {
                    "value": 90,
                    "color": "red"
                  }
                ]
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 7,
          "title": "Average GPU Utilization",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 0,
            "y": 24
          },
          "targets": [
            {
              "expr": "avg(DCGM_FI_DEV_GPU_UTIL{namespace='gpu-operator'})",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "decimals": 1,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "blue"
                  },
                  {
                    "value": 50,
                    "color": "green"
                  },
                  {
                    "value": 80,
                    "color": "yellow"
                  },
                  {
                    "value": 95,
                    "color": "red"
                  }
                ]
              }
            }
          },
          "options": {
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "value_and_name"
          }
        },
        {
          "id": 8,
          "title": "Average GPU Temperature",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 6,
            "y": 24
          },
          "targets": [
            {
              "expr": "avg(DCGM_FI_DEV_GPU_TEMP{namespace='gpu-operator'})",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "celsius",
              "decimals": 1,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "green"
                  },
                  {
                    "value": 70,
                    "color": "yellow"
                  },
                  {
                    "value": 85,
                    "color": "red"
                  }
                ]
              }
            }
          },
          "options": {
            "colorMode": "background",
            "textMode": "value_and_name"
          }
        },
        {
          "id": 9,
          "title": "Total GPU Memory Used",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 12,
            "y": 24
          },
          "targets": [
            {
              "expr": "sum(DCGM_FI_DEV_FB_USED{namespace='gpu-operator'}) / 1024",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "decgbytes",
              "decimals": 1
            }
          },
          "options": {
            "colorMode": "value",
            "textMode": "value_and_name"
          }
        },
        {
          "id": 10,
          "title": "Total GPU Power",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 18,
            "y": 24
          },
          "targets": [
            {
              "expr": "sum(DCGM_FI_DEV_POWER_USAGE{namespace='gpu-operator'})",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "watt",
              "decimals": 0
            }
          },
          "options": {
            "colorMode": "value",
            "textMode": "value_and_name"
          }
        },
        {
          "id": 11,
          "title": "Hardware Status Table",
          "type": "table",
          "gridPos": {
            "h": 10,
            "w": 24,
            "x": 0,
            "y": 28
          },
          "targets": [
            {
              "expr": "DCGM_FI_DEV_GPU_UTIL{namespace='gpu-operator'}",
              "format": "table",
              "instant": true,
              "refId": "A"
            },
            {
              "expr": "DCGM_FI_DEV_GPU_TEMP{namespace='gpu-operator'}",
              "format": "table",
              "instant": true,
              "refId": "B"
            },
            {
              "expr": "DCGM_FI_DEV_FB_USED{namespace='gpu-operator'} / 1024",
              "format": "table",
              "instant": true,
              "refId": "C"
            },
            {
              "expr": "DCGM_FI_DEV_POWER_USAGE{namespace='gpu-operator'}",
              "format": "table",
              "instant": true,
              "refId": "D"
            }
          ],
          "transformations": [
            {
              "id": "merge"
            },
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "__name__": true,
                  "namespace": true,
                  "job": true,
                  "instance": true,
                  "UUID": true,
                  "device": true,
                  "Hostname": true,
                  "DCGM_FI_DRIVER_VERSION": true,
                  "container": true,
                  "endpoint": true,
                  "modelName": true,
                  "service": true
                },
                "renameByName": {
                  "kubernetes_node": "Node",
                  "gpu": "GPU ID",
                  "Value #A": "GPU Util %",
                  "Value #B": "Temp °C",
                  "Value #C": "VRAM GB",
                  "Value #D": "Power W"
                }
              }
            }
          ],
          "options": {
            "showHeader": true,
            "sortBy": [
              {
                "displayName": "Node",
                "desc": false
              }
            ]
          },
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "auto",
                "displayMode": "auto"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "GPU Util %"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "percent"
                  },
                  {
                    "id": "decimals",
                    "value": 1
                  },
                  {
                    "id": "custom.displayMode",
                    "value": "gradient-gauge"
                  },
                  {
                    "id": "min",
                    "value": 0
                  },
                  {
                    "id": "max",
                    "value": 100
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Temp °C"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "celsius"
                  },
                  {
                    "id": "decimals",
                    "value": 0
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "VRAM GB"
                },
                "properties": [
                  {
                    "id": "decimals",
                    "value": 1
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Power W"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "watt"
                  },
                  {
                    "id": "decimals",
                    "value": 0
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 12,
          "title": "Network I/O (per node)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 38
          },
          "targets": [
            {
              "expr": "rate(node_network_receive_bytes_total{device!~'lo'}[5m])",
              "legendFormat": "{{instance}} - RX",
              "refId": "A"
            },
            {
              "expr": "rate(node_network_transmit_bytes_total{device!~'lo'}[5m])",
              "legendFormat": "{{instance}} - TX",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        },
        {
          "id": 13,
          "title": "Disk I/O (per node)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 38
          },
          "targets": [
            {
              "expr": "rate(node_disk_read_bytes_total[5m])",
              "legendFormat": "{{instance}} - Read",
              "refId": "A"
            },
            {
              "expr": "rate(node_disk_written_bytes_total[5m])",
              "legendFormat": "{{instance}} - Write",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["mean", "max", "last"]
            }
          }
        }
      ],
      "schemaVersion": 39,
      "version": 1
    },
    "overwrite": true
  }