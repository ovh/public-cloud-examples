{
  "dashboard": {
    "title": "vLLM Application Metrics - Production",
    "uid": "vllm-app-complete",
    "tags": ["vllm", "llm", "performance"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (Success)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(vllm:request_success_total[1m])) by (pod)",
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 2,
        "title": "Queue Depth",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "vllm:num_requests_running",
            "legendFormat": "{{pod}} - Running"
          },
          {
            "expr": "vllm:num_requests_waiting",
            "legendFormat": "{{pod}} - Waiting"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "custom": {"drawStyle": "line", "lineWidth": 2}
          }
        }
      },
      {
        "id": 3,
        "title": "Time to First Token (TTFT) - P50/P95/P99",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "End-to-End Request Latency - P50/P95/P99",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 2, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Token Generation Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(vllm:generation_tokens_total[1m])) by (pod)",
            "legendFormat": "{{pod}} - Generated"
          },
          {
            "expr": "sum(rate(vllm:prompt_tokens_total[1m])) by (pod)",
            "legendFormat": "{{pod}} - Prompt"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "tps",
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 6,
        "title": "KV Cache Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "vllm:kv_cache_usage_perc * 100",
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Prefix Cache Hit Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(vllm:prefix_cache_hits_total[5m]) / rate(vllm:prefix_cache_queries_total[5m]) * 100",
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "decimals": 1
          }
        }
      },
      {
        "id": 8,
        "title": "Request Queue Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:request_queue_time_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.1, "color": "yellow"},
                {"value": 0.5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Prefill Time vs Decode Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:request_prefill_time_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - Prefill P95"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:request_decode_time_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - Decode P95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3
          }
        }
      },
      {
        "id": 10,
        "title": "Inter-Token Latency",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket[5m])) by (le, pod))",
            "legendFormat": "{{pod}} - P95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 4
          }
        }
      },
      {
        "id": 11,
        "title": "Preemptions",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "targets": [
          {
            "expr": "rate(vllm:num_preemptions_total[5m])",
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 2,
            "color": {"mode": "fixed", "fixedColor": "orange"}
          }
        }
      },
      {
        "id": 12,
        "title": "Average Tokens per Request",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "targets": [
          {
            "expr": "rate(vllm:generation_tokens_total[5m]) / rate(vllm:request_success_total[5m])",
            "legendFormat": "{{pod}} - Output Tokens"
          },
          {
            "expr": "rate(vllm:prompt_tokens_total[5m]) / rate(vllm:request_success_total[5m])",
            "legendFormat": "{{pod}} - Input Tokens"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1
          }
        }
      },
      {
        "id": 13,
        "title": "Total Throughput",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 48},
        "targets": [
          {
            "expr": "sum(rate(vllm:request_success_total[5m]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 1, "color": "yellow"},
                {"value": 10, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 14,
        "title": "Avg TTFT P95",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 48},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 15,
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 48},
        "targets": [
          {
            "expr": "sum(vllm:num_requests_running)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        },
        "options": {
          "colorMode": "value"
        }
      },
      {
        "id": 16,
        "title": "Queued Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 48},
        "targets": [
          {
            "expr": "sum(vllm:num_requests_waiting)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 17,
        "title": "Cache Hit Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 48},
        "targets": [
          {
            "expr": "sum(rate(vllm:prefix_cache_hits_total[5m])) / sum(rate(vllm:prefix_cache_queries_total[5m])) * 100"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 30, "color": "yellow"},
                {"value": 70, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 18,
        "title": "KV Cache Usage",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 48},
        "targets": [
          {
            "expr": "avg(vllm:kv_cache_usage_perc) * 100"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 19,
        "title": "Total Requests (Last Hour)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 52},
        "targets": [
          {
            "expr": "sum(increase(vllm:request_success_total[1h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {"mode": "fixed", "fixedColor": "green"}
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 20,
        "title": "Total Tokens Generated (Last Hour)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 52},
        "targets": [
          {
            "expr": "sum(increase(vllm:generation_tokens_total[1h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        },
        "options": {
          "colorMode": "value"
        }
      },
      {
        "id": 21,
        "title": "Cached Tokens (Last Hour)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 52},
        "targets": [
          {
            "expr": "sum(increase(vllm:prompt_tokens_cached_total[1h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {"mode": "fixed", "fixedColor": "blue"}
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 22,
        "title": "Total Preemptions (Last Hour)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 52},
        "targets": [
          {
            "expr": "sum(increase(vllm:num_preemptions_total[1h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {"mode": "fixed", "fixedColor": "orange"}
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 23,
        "title": "Pod Performance Table",
        "type": "table",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 56},
        "targets": [
          {
            "expr": "vllm:num_requests_running",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "vllm:num_requests_waiting",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "rate(vllm:request_success_total[5m])",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "vllm:kv_cache_usage_perc * 100",
            "format": "table",
            "instant": true,
            "refId": "D"
          },
          {
            "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
            "format": "table",
            "instant": true,
            "refId": "E"
          }
        ],
        "transformations": [
          {
            "id": "merge"
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "job": true,
                "namespace": true,
                "service": true
              },
              "renameByName": {
                "pod": "Pod",
                "node": "Node",
                "Value #A": "Running",
                "Value #B": "Waiting",
                "Value #C": "Req/s",
                "Value #D": "Cache %",
                "Value #E": "TTFT P95"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Cache %"},
              "properties": [
                {"id": "unit", "value": "percent"},
                {"id": "decimals", "value": 1},
                {"id": "custom.displayMode", "value": "gradient-gauge"},
                {"id": "min", "value": 0},
                {"id": "max", "value": 100}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "TTFT P95"},
              "properties": [
                {"id": "unit", "value": "s"},
                {"id": "decimals", "value": 3}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Req/s"},
              "properties": [
                {"id": "unit", "value": "reqps"},
                {"id": "decimals", "value": 2}
              ]
            }
          ]
        }
      }
    ],
    "schemaVersion": 39,
    "version": 1
  },
  "overwrite": true
}
